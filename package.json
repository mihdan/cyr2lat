{
  "name": "cyr-to-lat",
  "license": "GPL-2.0-or-later",
  "scripts": {
    "dev": "webpack --mode development",
    "prod": "webpack --env production --mode production",
    "watch": "webpack --mode development --watch",
    "lint": "npx eslint 'webpack.config.js' 'src/js/**/*.js' 'assets/js/*.js' 'tests/js/**/*.js'",
    "test": "jest"
  },
  "jest": {
    "automock": false,
    "verbose": true,
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://domain.tld/"
    },
    "setupFiles": [
      "<rootDir>/tests/js/setupTests.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "transform": {
      "\\.[tj]sx?$": [
        "babel-jest",
        {
          "presets": [
            [
              "@babel/preset-env"
            ]
          ]
        }
      ]
    },
    "globals": {
      "Cyr2LatTablesObject": {
        "ajaxUrl": "http://test.test/wp-admin/admin-ajax.php",
        "action": "cyr-to-lat-save-table",
        "nonce": "some-nonce",
        "ctlLocale": "ru_RU",
        "localeWarning": "Active table \"{active_table}\" does not match the current site locale: \"ru_RU\". The \"ISO9\" table will be used for transliteration."
      }
    }
  },
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11.12.0"
  },
  "packageManager": "yarn@4.14.1",
  "dependencies": {
    "@wordpress/hooks": "^4.45.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@wordpress/eslint-plugin": "^25.1.0",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "eslint": "^10.3.0",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-fetch-mock": "^3.0.3",
    "mini-css-extract-plugin": "^2.10.2",
    "prettier": "^3.8.3",
    "terser-webpack-plugin": "^5.6.0",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-remove-empty-scripts": "^1.1.1"
  },
  "resolutions": {
    "flatted": "^3.4.2",
    "form-data": "^4.0.5",
    "js-yaml": "^4.1.1",
    "minimatch@npm:^3": "^3.1.5",
    "minimatch@npm:9.0.3": "^9.0.9",
    "minimatch@npm:^10": "^10.2.4",
    "picomatch@npm:^2": "^2.3.2",
    "picomatch@npm:^4": "^4.0.4",
    "punycode": "^2.3.1",
    "qs": "^6.14.1",
    "serialize-javascript": "^7.0.5",
    "svgo": "^4.0.1",
    "tar": "^7.5.13",
    "uuid": "^14.0.0"
  }
}
