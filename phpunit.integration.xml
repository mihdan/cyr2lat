<?xml version="1.0"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         bootstrap="tests/integration/bootstrap.php"
         colors="true"
         convertErrorsToExceptions="true"
         convertNoticesToExceptions="true"
         convertWarningsToExceptions="true"
         beStrictAboutTestsThatDoNotTestAnything="false"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd">
    <!--
        By default, tests/integration/bootstrap.php uses tests/integration/wp-tests-config.php.
        Override WP_PHPUNIT__TESTS_CONFIG only when a different local config is needed.
    -->
    <coverage>
        <include>
            <directory suffix=".php">src/php</directory>
            <file>cyr-to-lat.php</file>
        </include>
        <exclude>
            <directory>tests</directory>
            <directory>vendor</directory>
        </exclude>
    </coverage>
    <testsuites>
        <testsuite name="cyr2lat-integration-tests">
            <directory suffix="Test.php">tests/integration</directory>
        </testsuite>
    </testsuites>
</phpunit>
